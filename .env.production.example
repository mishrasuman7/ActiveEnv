# ============================================================
# ActiveEnv — PRODUCTION environment template (Alibaba Cloud ECS)
# Copy to .env on the server and fill in. NEVER commit the real .env.
# Host/port vars for Postgres + Redis are set by docker-compose.prod.yml,
# so you do not need DATABASE_URL / REDIS_URL here.
# ============================================================

# --- Django ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=CHANGE_ME_50_RANDOM_CHARS
DJANGO_DEBUG=false
# The ECS public IP and/or domain that will serve the API.
DJANGO_ALLOWED_HOSTS=YOUR_ECS_IP,api.yourdomain.com
# Origins allowed to POST (the deployed frontend). Include scheme.
CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
# Set true only once the API is behind HTTPS (TLS terminated by a proxy/SLB).
SECURE_COOKIES=false

# --- Postgres (compose injects host/port; these set the credentials) ---
POSTGRES_DB=activeenv
POSTGRES_USER=activeenv
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Secret vault (encrypts probeable secret values at rest) ---
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If unset, a key is derived from DJANGO_SECRET_KEY (fine for demo, set one for real).
ACTIVEENV_ENCRYPTION_KEY=

# --- Qwen via Alibaba Cloud Model Studio (OpenAI-compatible endpoint) ---
# Required for real intent inference. Without it, intent is skipped and probes
# still classify deterministically.
DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# --- Probes ---
# true  = simulation (no external creds; safe, reliable demo)
# false = real read-only probes against the targets in the submitted config
SIMULATE_PROBES=true
