# ============================================================
# ActiveEnv — environment template
# Copy to .env and fill in. NEVER commit the real .env.
# ============================================================

# --- Django ---
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Postgres (app datastore: runs, findings, audit log) ---
POSTGRES_DB=activeenv
POSTGRES_USER=activeenv
POSTGRES_PASSWORD=activeenv
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgres://activeenv:activeenv@localhost:5432/activeenv

# --- Redis (Celery broker + result backend) ---
REDIS_URL=redis://localhost:6379/0

# --- Qwen via Alibaba Cloud Model Studio (OpenAI-compatible endpoint) ---
# Get this key from Model Studio -> API-KEY. Required for intent inference.
DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
